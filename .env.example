# Application
DEBUG=false
USE_MOCK_LLM=true

# LLM — set USE_MOCK_LLM=false and provide a key for live calls
# LLM — Haiku recommended for dev/demo (lowest cost); use Sonnet only for teacher if needed
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
LLM_MODEL=claude-haiku-4-5
TEACHER_MODEL=claude-haiku-4-5
STUDENT_MODEL=microsoft/phi-2

# OpenAI (only if LLM_PROVIDER=openai)
OPENAI_API_KEY=
# LLM_MODEL=gpt-4o-mini
# TEACHER_MODEL=gpt-4o

# Database
DATABASE_URL=postgresql+asyncpg://fve:fve_secret@postgres:5432/fve

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_secret

# Redis
REDIS_URL=redis://redis:6379/0

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000

# Thresholds
HUMAN_REVIEW_THRESHOLD=0.6
TRAINING_CONFIDENCE_THRESHOLD=0.85
DUPLICATE_SIMILARITY_THRESHOLD=0.92

# Evaluation speed (optional — defaults are tuned for fast demos)
# BENCHMARK_MAX_SAMPLES=15
# ADVERSARIAL_MAX_CLAIMS=5
# EVAL_CONCURRENCY=5
# TRAINING_BLOCK_MISS_RATE_THRESHOLD=0.35
# Set BENCHMARK_MAX_SAMPLES=0 and ADVERSARIAL_MAX_CLAIMS=0 for full runs (55 + 15 claims)

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
